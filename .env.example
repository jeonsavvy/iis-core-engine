# =========================
# IIS Core Engine (ForgeMind)
# =========================
APP_ENV=development
API_V1_PREFIX=/api/v1

# Internal API token (Bearer)
# Required when APP_ENV=production (startup fail-fast if missing)
# When set, /api/v1/pipelines/* requires Authorization: Bearer <token>
INTERNAL_API_TOKEN=

# Supabase (server-only secrets)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=games
PUBLIC_GAMES_BASE_URL=https://cdn.example.com/games
PUBLIC_PORTAL_BASE_URL=https://arcade.example.com

# Vertex AI
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CONTROL_ENABLED=false
TELEGRAM_ALLOW_DANGEROUS_COMMANDS=false
TELEGRAM_CONFIRM_TTL_SECONDS=120
TELEGRAM_CONFIRM_SECRET=

# X posting
X_BEARER_TOKEN=
X_AUTO_POST_ENABLED=false
X_POSTS_PER_GAME_PER_DAY=1
X_DAILY_STOP_ON_ERROR=true
X_QUOTA_STATE_FILE=.x_quota_state.json

# GitHub archive
GITHUB_TOKEN=
GITHUB_ARCHIVE_REPO=
GITHUB_ARCHIVE_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com

# QA runtime
PLAYWRIGHT_REQUIRED=false
QA_SMOKE_TIMEOUT_SECONDS=8
QA_MIN_QUALITY_SCORE=40
QA_MIN_GAMEPLAY_SCORE=55
QA_MIN_VISUAL_SCORE=45
QA_MIN_ARTIFACT_CONTRACT_SCORE=70
# Builder currently enforces single-candidate mode for deterministic throughput.
BUILDER_CANDIDATE_COUNT=1
BUILDER_CODEGEN_ENABLED=false
BUILDER_CODEGEN_PASSES=1
BUILDER_CODEGEN_MAX_OUTPUT_TOKENS=12000
BUILDER_RUNTIME_MUTATION_ENABLED=false
BUILDER_FORCE_PRO_MODEL=true
BUILDER_SCOPE_GUARD_ENABLED=true
BUILDER_ASSET_MEMORY_ENABLED=true
BUILDER_QUALITY_FLOOR_ENFORCED=true
BUILDER_QUALITY_FLOOR_SCORE=82
BUILDER_PLAYABILITY_HARD_GATE=true
PIPELINE_DEFAULT_VERSION=forgeflow-v1

# Runtime policies
PIPELINE_POLL_INTERVAL_SECONDS=3
PIPELINE_STALE_AFTER_SECONDS=900
PIPELINE_WORKER_CONCURRENCY=1
TRIGGER_MIN_KEYWORD_LENGTH=1
# Comma-separated blocklist (case-insensitive), ex) test,forbidden
TRIGGER_FORBIDDEN_KEYWORDS=
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=3
